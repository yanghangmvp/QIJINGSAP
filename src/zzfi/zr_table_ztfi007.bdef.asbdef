managed implementation in class ZBP_TABLE_R_ZTFI007 unique;
strict ( 1 );
with draft;
extensible;
define behavior for ZR_TABLE_ZTFI007 alias FI007
persistent table zztfi007a
extensible
draft table zztfi007_d
etag master LocalLastChangedAt
lock master total etag LastChangedAt
authorization master ( global )
with additional save
{
  field ( mandatory : create )
  Recordid,
  Unitno;

  field ( readonly )
  CreatedBy,
  CreatedAt,
  LastChangedBy,
  LastChangedAt,
  LocalLastChangedAt;


  //  field ( readonly : update )
